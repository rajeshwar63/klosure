# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App
VITE_APP_URL=http://localhost:5173

# Klo / Phase 2 — Claude Sonnet 4.6 via the `klo-respond` edge function.
# The Anthropic key lives as a Supabase secret on the function (NOT here).
# These two are optional client-side overrides:
#   VITE_KLO_MODEL=claude-sonnet-4-6   # which model the function should use
#   VITE_KLO_USE_STUB=false            # set to true to bypass the edge function
#                                        and run on the Phase 1 heuristic stub
#                                        (useful when the function isn't deployed)

# Phase 12.3 — Razorpay
# Razorpay mode: 'test' (default) or 'live'. Flip in Vercel env vars at cutover.
VITE_RAZORPAY_MODE=test
# Razorpay secrets live as Supabase secrets, NOT in this file:
#   RAZORPAY_KEY_ID          rzp_test_… or rzp_live_…
#   RAZORPAY_KEY_SECRET      Razorpay key secret (shown once at key creation)
#   RAZORPAY_WEBHOOK_SECRET  generated when registering webhook in dashboard
#
# Deploy:
#   supabase functions deploy razorpay-create-subscription
#   supabase functions deploy razorpay-verify-subscription
#   supabase functions deploy razorpay-cancel-subscription
#   supabase functions deploy razorpay-webhook --no-verify-jwt

# Phase 14 — Transactional email (Resend)
# All set as Supabase secrets, NOT in this file:
#   RESEND_API_KEY   re_… (generate at https://resend.com/api-keys)
#   FROM_EMAIL       noreply@klosure.ai (must be a verified Resend sender)
#   FROM_NAME        Klosure
#   APP_URL          https://klosure.ai (used in CTA links inside emails)
#
# Apply DB migration once before deploying:
#   psql ... -f supabase/phase14_email_infrastructure.sql
#
# Deploy:
#   supabase functions deploy send-team-invite
#   supabase functions deploy send-invoice
#   supabase functions deploy send-welcome-email
#   supabase functions deploy send-buyer-share

# Phase B — Inbox + meeting integration (Aurinko + Recall.ai)
# All set as Supabase secrets, NOT in this file. The user only ever sees
# Klosure (and Google/Microsoft for the consent screen) — never the vendor
# names below.
#
#   AURINKO_APP_ID                Aurinko app's clientId
#   AURINKO_CLIENT_SECRET         Aurinko app's clientSecret
#   AURINKO_API_BASE              https://api.aurinko.io/v1
#   AURINKO_SIGNING_KEY           HMAC secret for verifying Aurinko webhooks
#   AURINKO_AUTH_STATE_SECRET     HMAC secret for the OAuth state JWT
#                                 (any random 32+ char string we generate)
#   RECALL_API_KEY                Recall workspace API key (Account → Developers)
#   RECALL_API_BASE               https://ap-northeast-1.recall.ai/api/v1
#                                 (or us-east-1 / eu-central-1 / etc — match
#                                 your Recall workspace region)
#   RECALL_WEBHOOK_SECRET         Svix signing secret from Recall webhooks page
#
# Apply DB migration once before deploying:
#   psql ... -f supabase/phase_b_aurinko_recall.sql
#
# Deploy edge functions:
#   supabase functions deploy aurinko-auth-start
#   supabase functions deploy aurinko-auth-finish
#   supabase functions deploy aurinko-revoke-grant
#   supabase functions deploy aurinko-webhook --no-verify-jwt
#   supabase functions deploy aurinko-process-email
#   supabase functions deploy aurinko-process-calendar
#   supabase functions deploy recall-webhook --no-verify-jwt
#   supabase functions deploy recall-process-meeting
#
# After deploying, register webhook URLs in each provider's dashboard:
#   Aurinko subscriptions → https://<project>.supabase.co/functions/v1/aurinko-webhook
#   Recall webhooks       → https://<project>.supabase.co/functions/v1/recall-webhook
